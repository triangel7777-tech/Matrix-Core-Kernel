{
  "title": "Matrix Core Release Asset Proof v2.5",
  "type": "object",
  "required": [
    "release_tag",
    "release_url",
    "asset_filename",
    "asset_sha256",
    "download_timestamp_utc",
    "verification_result",
    "truth_boundary"
  ],
  "properties": {
    "release_tag": {"type": "string"},
    "release_url": {"type": "string"},
    "asset_filename": {"type": "string"},
    "asset_size_bytes": {"type": "integer", "minimum": 1},
    "asset_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "download_timestamp_utc": {"type": "string"},
    "verification_command": {"type": "string"},
    "verification_result": {"type": "string", "enum": ["pass", "fail"]},
    "verifier": {"type": "string"},
    "truth_boundary": {"type": "string"}
  }
}
